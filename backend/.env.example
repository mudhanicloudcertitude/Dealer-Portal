# ========================================
# Dealer Portal - Environment Configuration
# ========================================

# Server Configuration
PORT=5000
NODE_ENV=production

# ── Salesforce Connection ────────────────
# SOAP Username-Password Flow (no Connected App needed)
# Just username + password + security token
SF_MODE=real
SF_LOGIN_URL=https://login.salesforce.com
SF_USERNAME=your.salesforce.username@domain.com
SF_PASSWORD=your_salesforce_password
SF_SECURITY_TOKEN=your_salesforce_security_token
SF_API_VERSION=v59.0

# ── MongoDB Atlas ────────────────────────
# Use your production MongoDB Atlas cluster connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dealer_portal?retryWrites=true&w=majority

# ── JWT Auth ─────────────────────────────
# Use a highly secure random string for signing JWT tokens in production
JWT_SECRET=your_super_secure_random_jwt_secret_key_here
JWT_EXPIRES_IN=8h

# ── Frontend URL ─────────────────────────
# Comma-separated list of allowed origins for CORS validation
# In production, set this to your Vercel live URLs
FRONTEND_URL=https://your-dealer-portal.vercel.app,http://localhost:5173

# ── Sync Scheduler ───────────────────────
# Cron schedule defining how often data is synchronized in background
SYNC_INTERVAL=*/2 * * * *
