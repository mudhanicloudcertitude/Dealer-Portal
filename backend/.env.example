# ========================================
# Dealer Portal - Backend Config Template
# ========================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env

PORT=5000
NODE_ENV=development

# MongoDB (Atlas or local). If connection fails, app falls back to local JSON mock DB.
MONGO_URI=mongodb://127.0.0.1:27017/dealer_portal

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# CORS — comma-separated allowed frontend origins
FRONTEND_URL=http://localhost:5173

# Salesforce (optional for local dev — leave blank to use mock data only)
SF_LOGIN_URL=https://login.salesforce.com
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_API_VERSION=v59.0
